# Telegram Media Downloader — environment overrides
#
# Copy this file to `.env` (next to docker-compose.yml) and uncomment the
# rows you want to set. None of these are required for a vanilla
# `docker compose up -d` install — they only unlock optional features.

# ---------------------------------------------------------------------------
# Timezone — used by container logs and the "last accessed" timestamps
# in the Maintenance UI. Defaults to UTC.
# ---------------------------------------------------------------------------
# TZ=Asia/Bangkok

# ---------------------------------------------------------------------------
# Debug log level — increases verbosity of the realtime monitor + downloader.
# Leave unset for normal operation.
# ---------------------------------------------------------------------------
# TGDL_DEBUG=1

# ---------------------------------------------------------------------------
# Split-disk setup — store downloads on a separate volume from the database
# ---------------------------------------------------------------------------
# By default downloads live at <TGDL_DATA_DIR>/downloads. Set this to move
# just the downloads tree to a different path (e.g. a large HDD) while
# keeping db.sqlite, sessions, logs, and backups on a faster disk (SSD).
#
# Docker: set TGDL_DATA_DIR to the SSD mount and TGDL_DOWNLOADS_DIR to the
# HDD mount, then add a second bind-mount in docker-compose.yml volumes:
#   - /mnt/ssd/tgdl/data:/app/data
#   - /mnt/hdd/tgdl/downloads:/mnt/hdd/downloads
#
# Bare metal / Synology native / Windows: set the env var before starting.
# The directory is created automatically on first boot if it does not exist.
#
# When unset, behaviour is identical to previous versions.
# ---------------------------------------------------------------------------
# TGDL_DOWNLOADS_DIR=/mnt/hdd/downloads

# ---------------------------------------------------------------------------
# Host port for the dashboard. Override when 3000 is already taken (Grafana,
# common dev servers). The container always listens on 3000 internally.
# ---------------------------------------------------------------------------
# TGDL_PORT=3000

# ---------------------------------------------------------------------------
# One-click in-dashboard auto-update
# ---------------------------------------------------------------------------
# Setting this token + booting with the `auto-update` profile lights up the
# **Install update** button in Settings → Maintenance. The button hands the
# pull-and-recreate work off to a watchtower sidecar; the dashboard never
# touches /var/run/docker.sock itself, so an RCE in the dashboard cannot
# escalate to host root.
#
# Generate a strong random token and keep it secret:
#   openssl rand -hex 32
# or
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Then start with the profile enabled:
#   docker compose --profile auto-update up -d
#
# Without this token (or without the profile) the dashboard falls back to
# linking the GitHub release page; updates remain manual via
# `docker compose pull && docker compose up -d`.
# ---------------------------------------------------------------------------
# WATCHTOWER_HTTP_API_TOKEN=replace-with-output-of-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Hardware-accelerated video thumbnails
# ---------------------------------------------------------------------------
# Pick a backend that matches your host's GPU AND uncomment the GPU
# passthrough block in docker-compose.yml. Leave unset (or empty) to keep
# CPU-only thumbnail generation, which works everywhere.
#
#   vaapi          — Intel iGPU (Iris Xe / UHD / Arc) and AMD on Linux
#   qsv            — Intel Quick Sync (Gen ≥ 8 — Skylake+)
#   cuda           — NVIDIA (requires nvidia-container-toolkit on the host)
#   videotoolbox   — macOS host
#   d3d11va        — Windows host running Linux containers under WSL2
#
# The container's entrypoint resolves /dev/dri device GIDs at boot and
# adds the in-container `node` user to a matching group, so a hard-coded
# `group_add` in compose isn't needed — the same image works on Synology
# DSM 6/7, Debian, RHEL, and Alpine hosts even though their render
# group GIDs differ.
# ---------------------------------------------------------------------------
# FFMPEG_HWACCEL=vaapi

# Set to 1 to print every step of the entrypoint's GPU passthrough
# detection (which device, which GID, which group it joined). Useful when
# `vainfo` inside the container returns nothing — read the boot
# transcript and the `[entrypoint:gpu]` lines tell you exactly where the
# chain broke.
# ENTRYPOINT_DEBUG_GPU=1

# ---------------------------------------------------------------------------
# Memory ceilings — V8 heap + container limit
# ---------------------------------------------------------------------------
# Two limits stack: V8 inside Node, and the kernel cgroup outside. Defaults
# are 8 GiB on both so a 1M-row library doesn't trip OOM during a dedup or
# integrity sweep — the streaming refactor in v2.13 keeps steady-state heap
# very low, but a one-shot SELECT of 100k+ rows still spikes briefly.
#
# Rules:
#   - TGDL_HEAP_MB must be strictly less than TGDL_MEM_LIMIT (rough rule:
#     leave ≥ 256 MiB headroom for native allocations: better-sqlite3,
#     sharp, ffmpeg, libvips, transformers WASM heap).
#   - On a 16 GiB host that runs other services too, you can raise both
#     to 12g / 12288 — the dashboard scales linearly with library size.
#   - On a 4 GiB Pi 4 / NAS, drop to: TGDL_MEM_LIMIT=2g, TGDL_HEAP_MB=1536.
#   - On a 1-2 GiB Synology J-series, drop to: TGDL_MEM_LIMIT=1g,
#     TGDL_HEAP_MB=768. Streaming queries in v2.13 keep boot OOM-safe even
#     at this size, but heavy `Find duplicates` / `Verify files` runs are
#     slower because each batch yield shrinks the pool of in-flight stat
#     calls.
# ---------------------------------------------------------------------------
# TGDL_MEM_LIMIT=8g
# TGDL_HEAP_MB=8192

# ---------------------------------------------------------------------------
# AI subsystem (Face clustering — Python sidecar)
# ---------------------------------------------------------------------------
# Off by default — flip `config.advanced.ai.enabled` + `faceClustering` in
# the dashboard to turn it on. Detection + 512-dim embeddings run inside a
# Python sidecar (`faces-service/`, insightface buffalo_l). See docs/AI.md
# for the full install + GPU matrix.
#
# Optional install paths (the dashboard never auto-installs):
#   docker compose --profile faces up        → pull the bundled tgdl-faces (CPU)
#   docker compose --profile faces-cuda up   → NVIDIA + nvidia-container-toolkit
#   docker compose --profile faces-openvino  → Intel iGPU/dGPU via /dev/dri
#   pip install -e faces-service/            → run the sidecar directly on the host
# ---------------------------------------------------------------------------

# Override URL for the faces sidecar. When the `faces` compose profile is
# up, this auto-resolves to http://tgdl-faces:8011 inside the network.
# Leave unset on bare-metal installs to let Node auto-spawn the bundled
# binary (or fall back to `python -m tgdl_faces`).
# FACES_SERVICE_URL=

# Refuse to auto-download the prebuilt PyInstaller binary on first use.
# Pair with a pre-staged binary at data/faces-service/bin/ for air-gapped
# deploys.
# TGDL_FACES_AUTO_DOWNLOAD=true

# Override the insightface model preset. Default: buffalo_l.
# Options: buffalo_l, antelopev2, buffalo_m, buffalo_s, buffalo_sc.
# All produce 512-dim embeddings — switching doesn't require re-scanning.
# antelopev2 (ResNet100) is the most accurate but ~2.3x slower on CPU.
# TGDL_FACES_DETECTOR_MODEL=buffalo_l

# CPU throttle ratio for face scanning. Sleep proportional to detection
# time so CPU gets rest between bursts. 0 = off, 0.5 = default (rest 50%
# of detection time), 5 = max. GPU users can set 0.
# TGDL_FACES_CPU_THROTTLE_RATIO=0.5

# Full env-var reference (27 knobs covering providers, det_size, batch
# size, timeouts, port range, mirror URLs, etc.) lives in docs/AI.md.

# ---------------------------------------------------------------------------
# Seekbar preview sidecar (Maintenance → Seekbar previews)
# ---------------------------------------------------------------------------
# Optional opt-in feature. Generates WebP sprite-sheet timeline previews
# for videos so the in-app player paints a thumbnail above the seekbar
# on hover. Implemented as a standalone Go service shipped in
# `seekbar-service/` — easier to scale and reuse than embedding ffmpeg
# directly in Node.
#
# All knobs ALSO surface in the dashboard's Maintenance → Seekbar previews
# page; this env block is only for headless / Docker-compose stacks that
# want config-as-code. The kv config wins when the dashboard sets a value.

# URL of the running sidecar. Set when the Go service runs as a
# separate container (`docker compose up seekbar`). Leave empty to use
# the value the dashboard writes into kv config.
# SEEKBAR_SIDECAR_URL=http://seekbar:8089

# Bearer token the dashboard sends as `X-API-Token`. Match the value
# the sidecar boots with (its own SEEKBAR_API_TOKEN env).
# SEEKBAR_API_TOKEN=

# Knobs forwarded to the sidecar process when the dashboard spawns one
# directly. For compose stacks, set these on the seekbar service block
# instead.
# SEEKBAR_HWACCEL=auto
# SEEKBAR_CONCURRENCY=2
# SEEKBAR_INTERVAL_SEC=5
# SEEKBAR_WIDTH=160
# SEEKBAR_COLUMNS=10
# SEEKBAR_MAX_TILES=200
# SEEKBAR_FORMAT=webp
# SEEKBAR_QUALITY=70
