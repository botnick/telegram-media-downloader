# Telegram Media Downloader — environment overrides
#
# Copy this file to `.env` (next to docker-compose.yml) and uncomment the
# rows you want to set. None of these are required for a vanilla
# `docker compose up -d` install — they only unlock optional features.

# ---------------------------------------------------------------------------
# Timezone — used by container logs and the "last accessed" timestamps
# in the Maintenance UI. Defaults to UTC.
# ---------------------------------------------------------------------------
# TZ=Asia/Bangkok

# ---------------------------------------------------------------------------
# Debug log level — increases verbosity of the realtime monitor + downloader.
# Leave unset for normal operation.
# ---------------------------------------------------------------------------
# TGDL_DEBUG=1

# ---------------------------------------------------------------------------
# Host port for the dashboard. Override when 3000 is already taken (Grafana,
# common dev servers). The container always listens on 3000 internally.
# ---------------------------------------------------------------------------
# TGDL_PORT=3000

# ---------------------------------------------------------------------------
# One-click in-dashboard auto-update
# ---------------------------------------------------------------------------
# Setting this token + booting with the `auto-update` profile lights up the
# **Install update** button in Settings → Maintenance. The button hands the
# pull-and-recreate work off to a watchtower sidecar; the dashboard never
# touches /var/run/docker.sock itself, so an RCE in the dashboard cannot
# escalate to host root.
#
# Generate a strong random token and keep it secret:
#   openssl rand -hex 32
# or
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Then start with the profile enabled:
#   docker compose --profile auto-update up -d
#
# Without this token (or without the profile) the dashboard falls back to
# linking the GitHub release page; updates remain manual via
# `docker compose pull && docker compose up -d`.
# ---------------------------------------------------------------------------
# WATCHTOWER_HTTP_API_TOKEN=replace-with-output-of-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Hardware-accelerated video thumbnails
# ---------------------------------------------------------------------------
# Pick a backend that matches your host's GPU AND uncomment the GPU
# passthrough block in docker-compose.yml. Leave unset (or empty) to keep
# CPU-only thumbnail generation, which works everywhere.
#
#   vaapi          — Intel iGPU (Iris Xe / UHD / Arc) and AMD on Linux
#   qsv            — Intel Quick Sync (Gen ≥ 8 — Skylake+)
#   cuda           — NVIDIA (requires nvidia-container-toolkit on the host)
#   videotoolbox   — macOS host
#   d3d11va        — Windows host running Linux containers under WSL2
#
# The container's entrypoint resolves /dev/dri device GIDs at boot and
# adds the in-container `node` user to a matching group, so a hard-coded
# `group_add` in compose isn't needed — the same image works on Synology
# DSM 6/7, Debian, RHEL, and Alpine hosts even though their render
# group GIDs differ.
# ---------------------------------------------------------------------------
# FFMPEG_HWACCEL=vaapi

# Set to 1 to print every step of the entrypoint's GPU passthrough
# detection (which device, which GID, which group it joined). Useful when
# `vainfo` inside the container returns nothing — read the boot
# transcript and the `[entrypoint:gpu]` lines tell you exactly where the
# chain broke.
# ENTRYPOINT_DEBUG_GPU=1

# ---------------------------------------------------------------------------
# Memory ceilings — V8 heap + container limit
# ---------------------------------------------------------------------------
# Two limits stack: V8 inside Node, and the kernel cgroup outside. Defaults
# are 8 GiB on both so a 1M-row library doesn't trip OOM during a dedup or
# integrity sweep — the streaming refactor in v2.13 keeps steady-state heap
# very low, but a one-shot SELECT of 100k+ rows still spikes briefly.
#
# Rules:
#   - TGDL_HEAP_MB must be strictly less than TGDL_MEM_LIMIT (rough rule:
#     leave ≥ 256 MiB headroom for native allocations: better-sqlite3,
#     sharp, ffmpeg, libvips, transformers WASM heap).
#   - On a 16 GiB host that runs other services too, you can raise both
#     to 12g / 12288 — the dashboard scales linearly with library size.
#   - On a 4 GiB Pi 4 / NAS, drop to: TGDL_MEM_LIMIT=2g, TGDL_HEAP_MB=1536.
#   - On a 1-2 GiB Synology J-series, drop to: TGDL_MEM_LIMIT=1g,
#     TGDL_HEAP_MB=768. Streaming queries in v2.13 keep boot OOM-safe even
#     at this size, but heavy `Find duplicates` / `Verify files` runs are
#     slower because each batch yield shrinks the pool of in-flight stat
#     calls.
# ---------------------------------------------------------------------------
# TGDL_MEM_LIMIT=8g
# TGDL_HEAP_MB=8192
