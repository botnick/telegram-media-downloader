{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    // The package is currently .js source. We don't run the compiler
    // on it (Node executes the .js directly), so just type-check via
    // tsc --noEmit when needed.
    "noEmit": true,
    // Accept .js source while we migrate file-by-file. checkJs is off
    // so we don't drown in JSDoc-inferred warnings on day one; turn it
    // on per-file once the file is converted to .ts.
    "allowJs": true,
    "checkJs": false,
    // The .js files use ESM relative imports without explicit .js
    // extensions in some places; tsc resolves them naturally. Strict
    // is still on for the .ts surface, just relaxed for legacy .js.
    "isolatedModules": true
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "references": [{ "path": "../shared" }]
}
