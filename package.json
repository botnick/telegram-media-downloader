{
    "name": "telegram-media-downloader",
    "version": "2.6.8",
    "private": true,
    "description": "Self-hosted Telegram media downloader — CLI + Web dashboard. MIT, no quotas.",
    "type": "module",
    "packageManager": "pnpm@11.0.4",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:workspaces": "turbo run test",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean && rm -rf node_modules .turbo",
        "format": "biome format --write",
        "doctor": "node apps/cli/src/index.js doctor",
        "start": "node apps/server/dist/index.js",
        "menu": "node apps/cli/src/index.js menu",
        "monitor": "node apps/cli/src/index.js monitor",
        "history": "node apps/cli/src/index.js history",
        "auth": "node apps/cli/src/index.js auth",
        "prod": "node runner.js",
        "migrate": "node scripts/migrate_json_to_sqlite.js",
        "prepare": "lefthook install || true"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/botnick/telegram-media-downloader.git"
    },
    "homepage": "https://github.com/botnick/telegram-media-downloader#readme",
    "bugs": {
        "url": "https://github.com/botnick/telegram-media-downloader/issues"
    },
    "keywords": [
        "telegram",
        "downloader",
        "media-downloader",
        "telegram-stories",
        "scraper",
        "backup",
        "channel-backup",
        "gramjs",
        "self-hosted",
        "automation",
        "telegram-api"
    ],
    "author": "botnick",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "@tgdl/core": "workspace:*",
        "@tgdl/shared": "workspace:*",
        "@types/node": "^25.6.0",
        "lefthook": "^2.1.6",
        "turbo": "^2.6.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
