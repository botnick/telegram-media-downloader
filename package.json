{
    "name": "telegram-media-downloader",
    "version": "2.23.0",
    "description": "Self-hosted Telegram media downloader — CLI + Web dashboard. MIT, no quotas.",
    "type": "module",
    "main": "src/index.js",
    "bin": {
        "telegram-downloader": "src/index.js"
    },
    "files": [
        "src",
        "scripts",
        "runner.js",
        "watchdog.ps1",
        "Dockerfile",
        "docker-compose.yml",
        "config.example.json",
        ".env.example",
        "LICENSE",
        "README.md",
        "CHANGELOG.md",
        "SECURITY.md"
    ],
    "scripts": {
        "start": "node src/index.js",
        "menu": "node src/index.js menu",
        "monitor": "node src/index.js monitor",
        "history": "node src/index.js history",
        "auth": "node src/index.js auth",
        "doctor": "node src/index.js doctor",
        "prod": "node runner.js",
        "dev": "node --watch src/web/server.js",
        "migrate": "node scripts/migrate_json_to_sqlite.js",
        "recover": "node scripts/recover_groups.js",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write . && npm run check:oom",
        "check:oom": "sh scripts/check-oom-patterns.sh",
        "pre-download-models": "node scripts/pre-download-models.js",
        "build:seekbar": "node scripts/build-seekbar.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "lefthook install || exit 0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/botnick/telegram-media-downloader.git"
    },
    "homepage": "https://github.com/botnick/telegram-media-downloader#readme",
    "bugs": {
        "url": "https://github.com/botnick/telegram-media-downloader/issues"
    },
    "keywords": [
        "telegram",
        "downloader",
        "media-downloader",
        "telegram-stories",
        "scraper",
        "backup",
        "channel-backup",
        "gramjs",
        "self-hosted",
        "automation",
        "telegram-api"
    ],
    "author": "botnick",
    "license": "MIT",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1042.0",
        "@aws-sdk/lib-storage": "^3.1042.0",
        "@huggingface/transformers": "^4.2.0",
        "better-sqlite3": "^12.9.0",
        "express": "^4.18.2",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.0.0",
        "sharp": "^0.34.5",
        "ssh2-sftp-client": "^11.0.0",
        "telegram": "^2.19.0",
        "ws": "^8.20.0"
    },
    "optionalDependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@ffprobe-installer/ffprobe": "^2.1.2",
        "basic-ftp": "^5.0.5",
        "dropbox": "^10.34.0",
        "googleapis": "^144.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "lefthook": "^2.1.6",
        "vitest": "^2.1.4"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
