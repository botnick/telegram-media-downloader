{
    "name": "@tgdl/cli",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.js",
    "bin": {
        "telegram-downloader": "./src/index.js"
    },
    "scripts": {
        "build": "echo 'CLI is .js source — Node executes directly'",
        "dev": "echo 'CLI is interactive — run via: node apps/cli/src/index.js'",
        "start": "node src/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "biome check src",
        "clean": "rm -rf dist *.tsbuildinfo"
    },
    "dependencies": {
        "@tgdl/core": "workspace:*",
        "@tgdl/shared": "workspace:*",
        "telegram": "^2.19.0"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "tsx": "^4.21.0",
        "typescript": "catalog:"
    }
}
