{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.*", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "TGDL_DEBUG",
    "TGDL_DATA_DIR",
    "TZ",
    "TRUST_PROXY",
    "FFMPEG_PATH",
    "FFMPEG_HWACCEL",
    "GIT_SHA",
    "BUILT_AT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "package.json",
        "tsconfig*.json",
        "vite.config.ts"
      ],
      "outputs": ["dist/**", ".vite/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx,js,jsx}", "../../eslint.config.js"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx}", "tsconfig*.json"],
      "outputs": ["*.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx}", "tests/**", "vitest.config.ts"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
